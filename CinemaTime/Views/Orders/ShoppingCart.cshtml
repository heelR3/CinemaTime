@section Scripts {

    <script src="https://www.paypal.com/sdk/js?client-id=AZdzQENrorJdXWQX9c8fm6EZtlfwoHirlKKGiU1HFn5Y5L72QLlzrw5D5chgmHbY0i81WLz35n6i2_lb&currency=USD"></script>

    <script>
        paypal.Buttons({

            createOrder: function (data, actions) {
                return actions.order.create({
                    purchase_units: [{
                        amount: {
                            value: '@Model.shoppingCartTotal.ToString(System.Globalization.CultureInfo.InvariantCulture)'
                        }
                    }]
                });
            },

            onApprove: function (data, actions) {
                return actions.order.capture().then(function (details) {
                    window.location.href = '@Url.Action("CompleteOrder", "Orders")';
                });
            }

        }).render('#paypal-btn');

    </script>

}